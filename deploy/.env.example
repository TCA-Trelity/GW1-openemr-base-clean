# Railway OpenEMR deploy — variable template (placeholders only; set real
# values in the Railway dashboard, never in the repo). See railway-runbook.md.

# --- OpenEMR source (this fork) ---
FLEX_REPOSITORY=https://github.com/TCA-Trelity/GW1-openemr-base-clean.git
FLEX_REPOSITORY_BRANCH=claude/ehr-architecture-defense-gg486o

# --- Database wiring ---
MYSQL_HOST=mariadb.railway.internal
MYSQL_ROOT_PASS=__set_in_railway_reference_to_mariadb_root_password__
MYSQL_USER=openemr
MYSQL_PASS=__generate_in_railway__
MYSQL_DATABASE=openemr

# --- OpenEMR admin login (rotate away from defaults) ---
OE_USER=admin
OE_PASS=__generate_in_railway__
