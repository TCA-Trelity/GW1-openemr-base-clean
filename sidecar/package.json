{
  "name": "clinical-copilot-sidecar",
  "version": "0.1.0",
  "private": true,
  "description": "Clinical Co-Pilot sidecar: preparation pipeline, fact store, citation gate, and chat API beside an untouched OpenEMR (see ARCHITECTURE.md)",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "seed-ehr": "tsx src/scripts/seed-ehr.ts",
    "load-test": "tsx src/scripts/load-test.ts",
    "eval": "tsx eval/run.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:eval": "tsc -p eval --noEmit",
    "eval:gate": "tsx eval/gate.ts",
    "eval:baseline": "tsx eval/gate.ts --write-baseline",
    "verify:pgvector": "tsx src/scripts/verify-pgvector.ts",
    "fixtures:documents": "tsx eval/fixtures/generate-documents.ts",
    "hooks:install": "git -C .. config core.hooksPath .githooks && echo pre-push eval gate installed"
  },
  "dependencies": {
    "@fastify/multipart": "^10.1.0",
    "@fastify/static": "^9.1.3",
    "@langchain/core": "^1.2.2",
    "@langchain/langgraph": "^1.4.7",
    "fastify": "^5.2.0",
    "langfuse": "^3.38.20",
    "pdfjs-dist": "^6.1.200",
    "pg": "^8.22.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.20.0",
    "playwright-core": "^1.61.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
