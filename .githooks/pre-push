#!/bin/sh
# Week 2 (D.4, REQ S4/R6, D5): PR-blocking Git Hook — the local leg of the eval gate.
# Runs the full deterministic eval suite (incl. the tiered category gate against
# eval/baseline.json) before any push that contains sidecar changes. The CI leg is
# .github/workflows/evals.yml on pull_request; this hook catches the regression one
# step earlier, on the developer's machine.
#
# Install once per clone:   git config core.hooksPath .githooks
#                           (or: cd sidecar && npm run hooks:install)
# Bypassing with --no-verify is visible in the push and the CI leg still gates the PR.

# Only run when the outgoing range touches sidecar/** (docs-only pushes stay instant).
RANGE_TOUCHES_SIDECAR=0
while read -r _local_ref local_sha _remote_ref remote_sha; do
    if [ "$local_sha" = "0000000000000000000000000000000000000000" ]; then
        continue # branch deletion
    fi
    if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
        RANGE="$local_sha"
    else
        RANGE="$remote_sha..$local_sha"
    fi
    if git diff --name-only "$RANGE" 2>/dev/null | grep -q '^sidecar/'; then
        RANGE_TOUCHES_SIDECAR=1
    fi
done

if [ "$RANGE_TOUCHES_SIDECAR" -eq 0 ]; then
    exit 0
fi

echo "pre-push: sidecar changes detected — running the eval gate (npm run eval)..."
cd "$(git rev-parse --show-toplevel)/sidecar" || exit 1

if [ ! -d node_modules ]; then
    echo "pre-push: sidecar/node_modules missing — run 'npm ci' in sidecar/ first" >&2
    exit 1
fi

npm run eval
STATUS=$?
if [ $STATUS -ne 0 ]; then
    echo "" >&2
    echo "pre-push BLOCKED: the eval gate failed (see category table above)." >&2
    echo "Fix the regression or, for a deliberate re-baseline, run 'npm run eval:baseline'" >&2
    echo "and commit the eval/baseline.json diff for review." >&2
fi
exit $STATUS
